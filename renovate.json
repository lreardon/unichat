{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "description": "Auto-merge patch and minor updates if CI passes",
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Major versions require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Security advisories get immediate PRs",
      "matchCategories": ["security"],
      "prPriority": 10
    }
  ],
  "schedule": ["before 9am on Monday"],
  "timezone": "Australia/Sydney"
}
