# Local Homebrew PostgreSQL (created in this session)
DATABASE_URL=postgresql+psycopg:///unichat
# Docker alternative
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/unichat
CURATED_DIR=universities/unsw-edu-au/domains
EMBEDDING_BACKEND=auto
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_ALLOW_DOWNLOAD=false
EMBEDDING_DIMENSIONS=256
RERANKER_BACKEND=auto
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_ALLOW_DOWNLOAD=false
CHUNK_SIZE_CHARS=1400
CHUNK_OVERLAP_CHARS=250
RETRIEVAL_DENSE_CANDIDATES=120
RETRIEVAL_SPARSE_CANDIDATES=120
RETRIEVAL_FUSED_CANDIDATES=80
RETRIEVAL_RRF_K=60
RETRIEVAL_NEIGHBOR_WINDOW=1
TOP_K=8
DENSE_WEIGHT=0.65
SPARSE_WEIGHT=0.35
MIN_SCORE=0.2
ANSWER_GENERATION_BACKEND=ollama
ANSWER_GENERATION_MODEL=gemma4
ANSWER_GENERATION_BASE_URL=http://127.0.0.1:11434
ANSWER_GENERATION_TIMEOUT_S=60
ANSWER_GENERATION_TEMPERATURE=0.1
ANSWER_GENERATION_MAX_TOKENS=512
ANSWER_GENERATION_CONTEXT_K=6
ANSWER_GENERATION_MAX_CHUNK_CHARS=1800
